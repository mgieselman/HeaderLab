{
  "name": "headerlab",
  "version": "1.0.0",
  "description": "HeaderLab — Email Header Analyzer",
  "type": "module",
  "engines": {
    "node": ">=18.12.0",
    "npm": ">=8.19.2"
  },
  "private": true,
  "scripts": {
    "clean": "node -e \"const fs=require('fs');const p='Pages';if(fs.existsSync(p))fs.readdirSync(p).filter(f=>f!=='coverage'&&f!=='test').forEach(f=>fs.rmSync(p+'/'+f,{recursive:true,force:true}))\"",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "serve": "vite",
    "dev": "vite",
    "start": "vite --https",
    "preview": "vite preview",
    "test": "vitest run",
    "test:debug": "vitest run --reporter=verbose",
    "test:watch": "vitest",
    "lint": "eslint \"*.{js,ts}\" \"src/**/*\"",
    "lint:fix": "eslint --fix \"*.{js,ts}\" \"src/**/*\"",
    "size": "size-limit",
    "pretest": "npm run lint",
    "prebuild": "npm run clean"
  },
  "keywords": [],
  "repository": {
    "type": "git",
    "url": "https://github.com/mgieselman/headerlab.git"
  },
  "author": "Stephen Griffin",
  "license": "MIT",
  "config": {
    "app_to_debug": "outlook",
    "app_type_to_debug": "desktop",
    "dev_server_port": 44336
  },
  "bugs": {
    "url": "https://github.com/mgieselman/headerlab/issues"
  },
  "homepage": "https://github.com/mgieselman/headerlab#readme",
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@size-limit/file": "^12.1.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^25.5.0",
    "@types/office-js": "^1.0.589",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-node": "^11.1.0",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "size-limit": "^12.1.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@azure/msal-browser": "^5.2.0",
    "@microsoft/applicationinsights-web": "^3.3.11",
    "@microsoft/office-js": "^1.1.110",
    "codepage": "^1.15.0",
    "dayjs": "^1.11.20",
    "stacktrace-js": "^2.0.2"
  },
  "overrides": {
    "tmp": "^0.2.5",
    "@azure/msal-browser": "^5.2.0"
  },
  "-vs-binding": {
    "BeforeBuild": [
      "build:dev"
    ],
    "Clean": [
      "clean"
    ]
  }
}
